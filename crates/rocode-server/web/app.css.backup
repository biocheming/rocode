:root {
  --bg-main: #0f1727;
  --bg-shell: #1a2438;
  --bg-panel: #101824;
  --bg-elev: rgba(255, 255, 255, 0.04);
  --line-soft: rgba(255, 255, 255, 0.08);
  --text-main: #e8edf7;
  --text-dim: #8ea3c2;
  --accent: #7eb8ff;
  --accent-soft: #a9ceff;
  --accent-strong: #3d91ff;
  --ok: #47d199;
  --warn: #ffc167;
  --error: #ff7f7f;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  height: 100%;
  color: var(--text-main);
  background: radial-gradient(1000px 600px at 20% -10%, #5f86c7 0%, #3b5e98 40%, #334e80 100%);
  font-family: "Space Grotesk", "IBM Plex Sans", "Segoe UI", sans-serif;
}

body {
  padding: 0;
}

.shell {
  height: 100dvh;
  max-height: none;
  background: linear-gradient(180deg, #213657 0%, #1a2c49 100%);
  border-radius: 0;
  border: 0;
  box-shadow: none;
  overflow: hidden;
  display: grid;
  grid-template-columns: 280px 1fr;
}

.shell[data-theme="graphite"] {
  background: linear-gradient(180deg, #2f3544 0%, #252b38 100%);
}

.shell[data-theme="sunset"] {
  background: linear-gradient(180deg, #4a3f56 0%, #3c3246 100%);
}

.shell[data-theme="daylight"] {
  background: linear-gradient(180deg, #4b6a8f 0%, #3f5c7f 100%);
}

.sidebar {
  background: linear-gradient(180deg, #2a3f64 0%, #283b60 100%);
  border-right: 1px solid rgba(255, 255, 255, 0.05);
  display: flex;
  flex-direction: column;
  padding: 14px 12px 12px;
}

.sidebar-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.window-buttons span {
  display: inline-block;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  margin-right: 8px;
}

.sidebar-toggle {
  width: 28px;
  height: 28px;
  border: 1px solid var(--line-soft);
  background: rgba(255, 255, 255, 0.06);
  border-radius: 8px;
  cursor: pointer;
}

.sidebar-toggle span {
  display: block;
  width: 14px;
  height: 14px;
  margin: 5px auto;
  border: 1px solid var(--text-main);
  border-radius: 3px;
}

.menu {
  display: grid;
  gap: 8px;
}

.menu-item {
  width: 100%;
  border: 1px solid transparent;
  border-radius: 10px;
  background: transparent;
  color: var(--text-main);
  text-align: left;
  font-size: 15px;
  padding: 10px 12px;
  cursor: pointer;
  transition: all 160ms ease;
}

.menu-item:hover {
  background: rgba(255, 255, 255, 0.08);
}

.menu-item.active {
  background: rgba(255, 255, 255, 0.13);
  border-color: rgba(255, 255, 255, 0.1);
  font-weight: 600;
}

.search-wrap {
  margin: 14px 0 12px;
}

.search-wrap input {
  width: 100%;
  border-radius: 10px;
  border: 1px solid var(--line-soft);
  background: rgba(0, 0, 0, 0.16);
  color: var(--text-main);
  padding: 10px 12px;
}

.project-panel {
  min-height: 0;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.project-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.project-head h2 {
  margin: 0;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-dim);
}

.project-tree {
  overflow: auto;
  padding-right: 4px;
  display: grid;
  gap: 10px;
}

.project-card {
  border: 1px solid rgba(255, 255, 255, 0.05);
  background: rgba(0, 0, 0, 0.12);
  border-radius: 12px;
  padding: 8px;
}

.project-trigger {
  width: 100%;
  display: flex;
  justify-content: space-between;
  gap: 8px;
  border: 0;
  background: transparent;
  color: var(--text-main);
  text-align: left;
  padding: 6px;
  border-radius: 8px;
  cursor: pointer;
}

.project-trigger.active {
  background: rgba(126, 184, 255, 0.14);
}

.project-trigger:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.project-name {
  font-weight: 600;
  font-size: 14px;
}

.project-meta {
  color: var(--text-dim);
  font-size: 12px;
}

.session-list {
  margin-top: 8px;
  border-top: 1px dashed rgba(255, 255, 255, 0.15);
  padding-top: 8px;
  display: grid;
  gap: 6px;
}

.session-btn {
  width: 100%;
  border: 1px solid rgba(255, 255, 255, 0.04);
  background: rgba(255, 255, 255, 0.02);
  border-radius: 8px;
  color: var(--text-main);
  text-align: left;
  padding: 8px;
  cursor: pointer;
}

.session-btn:hover {
  border-color: rgba(126, 184, 255, 0.32);
}

.session-btn.active {
  border-color: rgba(126, 184, 255, 0.42);
  background: rgba(126, 184, 255, 0.1);
}

.session-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.session-title {
  display: block;
  font-size: 13px;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.session-date {
  display: block;
  font-size: 11px;
  color: var(--text-dim);
  margin-top: 3px;
}

.session-runtime {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 6px;
}

.session-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8px;
  min-height: 20px;
}

.execution-panel {
  margin: 0 24px 12px;
  padding: 14px 16px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(12px);
}

.execution-panel.hidden {
  display: none;
}

.execution-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}

.execution-panel-head h4 {
  margin: 4px 0 0;
  font-size: 16px;
}

.execution-summary-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.execution-tree {
  list-style: none;
  margin: 0;
  padding-left: 14px;
  border-left: 1px solid rgba(255, 255, 255, 0.08);
  display: grid;
  gap: 10px;
}

.execution-node {
  position: relative;
}

.execution-node::before {
  content: "";
  position: absolute;
  left: -14px;
  top: 13px;
  width: 10px;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.execution-node-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.execution-kind {
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.execution-label {
  font-weight: 600;
}

.execution-node-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px;
  margin: 4px 0 0 0;
  color: var(--text-dim);
  font-size: 12px;
}

.recovery-actions,
.recovery-checkpoints {
  display: grid;
  gap: 10px;
}

.recovery-item {
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  padding: 10px 12px;
  background: rgba(0, 0, 0, 0.12);
}

.recovery-item h5 {
  margin: 0 0 6px;
  font-size: 14px;
}

.recovery-item p {
  margin: 0;
  color: var(--text-dim);
  font-size: 12px;
  line-height: 1.5;
}

.recovery-item-actions {
  margin-top: 10px;
  display: flex;
  justify-content: flex-end;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 9px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.06);
  color: var(--text-main);
  font-size: 12px;
  line-height: 1;
}

.meta-pill .meta-label {
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  font-size: 10px;
}

.sidebar-footer {
  margin-top: 10px;
}

.workspace {
  position: relative;
  background: radial-gradient(circle at 70% 22%, rgba(126, 184, 255, 0.14), transparent 40%),
    linear-gradient(180deg, #0d131e 0%, #0b1119 100%);
  display: grid;
  grid-template-rows: 1fr auto;
}

.bg-layer {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(126, 184, 255, 0.08) 1px, transparent 1px),
    radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
  background-size: 28px 28px, 160px 160px;
  background-position: 0 0, 40px 80px;
  pointer-events: none;
}

.hero,
.conversation,
.composer-shell {
  position: relative;
  z-index: 1;
}

.hero {
  display: grid;
  place-content: center;
  text-align: center;
  gap: 8px;
  padding: 24px;
}

.hero-logo {
  margin: 0;
  color: var(--text-dim);
  letter-spacing: 0.18em;
  font-size: 11px;
}

.hero h1 {
  margin: 0;
  font-size: clamp(34px, 5vw, 52px);
  line-height: 1.05;
}

.hero-sub {
  margin: 0;
  color: var(--text-dim);
}

.hero-actions {
  margin-top: 14px;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10px;
}

.chip-action {
  border-radius: 999px;
  border: 1px solid var(--line-soft);
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-main);
  padding: 9px 14px;
  cursor: pointer;
}

.chip-action:hover {
  border-color: rgba(126, 184, 255, 0.5);
  background: rgba(126, 184, 255, 0.14);
}

.conversation {
  min-height: 0;
  display: grid;
  grid-template-rows: auto 1fr;
  padding: 20px 24px 8px;
}

.conversation-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  border-bottom: 1px solid var(--line-soft);
  padding-bottom: 10px;
}

.conversation-head-main {
  min-width: 0;
}

.header-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.label {
  margin: 0;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.conversation-header h3 {
  margin: 6px 0 0;
  font-size: 20px;
}

.session-runtime-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 10px;
}

.ghost-btn {
  border: 1px solid var(--line-soft);
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-main);
  border-radius: 8px;
  padding: 8px 12px;
  cursor: pointer;
}

.ghost-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.ghost-danger {
  border-color: rgba(255, 127, 127, 0.45);
  color: #ffb0b0;
}

.message-feed {
  overflow: auto;
  padding: 16px 2px 8px;
  display: grid;
  gap: 10px;
}

.message {
  max-width: min(760px, 90%);
  border-radius: 14px;
  border: 1px solid var(--line-soft);
  background: rgba(255, 255, 255, 0.04);
  padding: 10px 12px;
}

.message.user {
  justify-self: end;
  background: rgba(126, 184, 255, 0.18);
  border-color: rgba(126, 184, 255, 0.42);
}

.message.assistant {
  justify-self: start;
}

.message.system,
.message.tool {
  justify-self: center;
  width: min(860px, 96%);
  background: rgba(0, 0, 0, 0.26);
}

.message.status {
  justify-self: center;
  width: min(760px, 96%);
  background: rgba(126, 184, 255, 0.1);
  border-color: rgba(126, 184, 255, 0.34);
}

.message.status.success {
  background: rgba(71, 209, 153, 0.12);
  border-color: rgba(71, 209, 153, 0.42);
}

.message.status.warning {
  background: rgba(255, 193, 103, 0.12);
  border-color: rgba(255, 193, 103, 0.42);
}

.message.status.error {
  background: rgba(255, 127, 127, 0.12);
  border-color: rgba(255, 127, 127, 0.42);
}

.message.tool.warning {
  border-color: rgba(255, 193, 103, 0.42);
}

.message.tool.success {
  border-color: rgba(71, 209, 153, 0.42);
}

.message.tool.error {
  border-color: rgba(255, 127, 127, 0.42);
}

.message.scheduler-stage {
  justify-self: center;
  width: min(820px, 96%);
  background: rgba(18, 25, 38, 0.88);
  border-color: rgba(126, 184, 255, 0.24);
}

.message.scheduler-stage.success {
  border-color: rgba(71, 209, 153, 0.42);
}

.message.scheduler-stage.warning {
  border-color: rgba(255, 193, 103, 0.42);
}

.message.scheduler-stage.error {
  border-color: rgba(255, 127, 127, 0.42);
}

.message-meta {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--text-dim);
  margin-bottom: 6px;
}

.stage-divider {
  height: 1px;
  background: rgba(255, 255, 255, 0.08);
  margin: 0 0 10px 0;
}

.stage-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.stage-chip {
  border-radius: 999px;
  border: 1px solid var(--line-soft);
  background: rgba(255, 255, 255, 0.05);
  padding: 4px 10px;
  font-size: 11px;
  color: var(--text-dim);
}

.stage-chip.primary {
  color: var(--accent);
  border-color: rgba(126, 184, 255, 0.32);
}

.status-chip.running {
  color: var(--accent-soft);
  border-color: rgba(126, 184, 255, 0.4);
}

.status-chip.running::before {
  content: "◌";
  display: inline-block;
  margin-right: 6px;
  animation: scheduler-spin 1s linear infinite;
}

.status-chip.start {
  color: var(--accent-soft);
  border-color: rgba(126, 184, 255, 0.32);
}

.status-chip.waiting {
  color: var(--warn);
  border-color: rgba(255, 193, 103, 0.45);
}

.status-chip.cancelling {
  color: var(--warn);
  border-color: rgba(255, 193, 103, 0.45);
}

.status-chip.cancelling::before {
  content: "◌";
  display: inline-block;
  margin-right: 6px;
  animation: scheduler-spin 0.7s linear infinite;
}

.status-chip.cancelled {
  color: var(--error);
  border-color: rgba(255, 127, 127, 0.45);
}

.status-chip.done {
  color: var(--ok);
  border-color: rgba(71, 209, 153, 0.45);
}

.status-chip.blocked {
  color: var(--error);
  border-color: rgba(255, 127, 127, 0.45);
}

.status-chip.error {
  color: var(--error);
  border-color: rgba(255, 127, 127, 0.45);
}

.stage-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
  margin-bottom: 10px;
}

.stage-field {
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.03);
  border-radius: 10px;
  padding: 8px 10px;
  color: var(--text-main);
  font-size: 12px;
  min-height: 36px;
}

.stage-field-secondary {
  border-color: rgba(255, 255, 255, 0.04);
  background: rgba(255, 255, 255, 0.018);
}

.stage-field-secondary .stage-field-label {
  color: rgba(255, 255, 255, 0.42);
}

.stage-field-secondary .stage-field-value {
  color: var(--text-dim);
  font-size: 12px;
}

.stage-activity {
  grid-column: 1 / -1;
  margin: 0;
}

.stage-section {
  grid-column: 1 / -1;
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.028);
  border-radius: 10px;
  padding: 10px 12px;
}

.stage-section-label {
  color: var(--text-dim);
  font-size: 11px;
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.stage-section-body {
  margin: 0;
  white-space: pre-wrap;
  font-family: inherit;
  line-height: 1.5;
  color: var(--text-main);
}

.stage-field-label {
  color: var(--text-dim);
  font-size: 11px;
  margin-bottom: 4px;
}

.stage-field-value {
  color: var(--text-main);
  font-size: 13px;
  line-height: 1.45;
}

.stage-caps-summary {
  color: var(--accent-soft);
  font-size: 13px;
}

.stage-activity-body {
  margin: 0;
  white-space: pre-wrap;
  font-family: inherit;
  line-height: 1.45;
  color: var(--text-main);
}

.stage-capabilities {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 6px 0;
}

.stage-caps-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.stage-caps-row .stage-field-label {
  margin-bottom: 0;
  min-width: 72px;
}

.stage-cap-chip {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 11px;
  line-height: 1.4;
}

.stage-cap-chip.skill {
  background: rgba(126, 184, 255, 0.15);
  color: var(--accent-soft);
}

.stage-cap-chip.agent {
  background: rgba(163, 230, 163, 0.15);
  color: #a3e6a3;
}

.stage-cap-chip.category {
  background: rgba(255, 203, 107, 0.15);
  color: #ffcb6b;
}

.stage-decision {
  grid-column: 1 / -1;
  border: 1px solid rgba(126, 184, 255, 0.2);
  background: rgba(126, 184, 255, 0.06);
  border-radius: 12px;
  padding: 10px 12px;
}

.decision-title {
  font-weight: 700;
  margin-bottom: 8px;
  color: var(--accent-soft);
}

.decision-row {
  display: flex;
  gap: 8px;
  align-items: baseline;
  margin-bottom: 6px;
}

.decision-label {
  color: var(--text-dim);
  min-width: 92px;
  font-weight: 700;
}

.decision-value.success {
  color: var(--ok);
  font-weight: 700;
}

.decision-value.warning {
  color: var(--warn);
  font-weight: 700;
}

.decision-value.error {
  color: var(--error);
  font-weight: 700;
}

.decision-value.info {
  color: var(--accent-soft);
  font-weight: 700;
}

.decision-value.muted {
  color: var(--text-dim);
}

.decision-value.status {
  color: var(--warn);
  font-weight: 700;
}

.decision-value.status[data-status="done"] {
  color: var(--ok);
}

.decision-value.status[data-status="blocked"] {
  color: var(--error);
}

.decision-section-title {
  margin-top: 10px;
  margin-bottom: 4px;
  color: var(--accent-soft);
  font-weight: 700;
}

.stage-decision[data-section-spacing="tight"] .decision-section-title {
  margin-top: 4px;
}

.decision-section-body {
  margin: 0;
  white-space: pre-wrap;
  font-family: inherit;
  line-height: 1.45;
}

.tool-summary {
  margin-top: 10px;
  color: var(--text-main);
  line-height: 1.45;
}

.question-interaction {
  margin-top: 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  flex-wrap: wrap;
}

.question-action-buttons {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.question-action-btn {
  border: 1px solid var(--line-soft);
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-main);
  border-radius: 999px;
  padding: 6px 12px;
  font-size: 12px;
  cursor: pointer;
}

.question-action-btn.primary {
  border-color: rgba(126, 184, 255, 0.38);
  color: var(--accent-soft);
}

.question-action-btn:disabled {
  opacity: 0.55;
  cursor: default;
}

.tool-grid {
  margin-top: 10px;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
}

.tool-field {
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.03);
  border-radius: 10px;
  padding: 8px 10px;
}

.tool-field-label {
  color: var(--text-dim);
  font-size: 11px;
  margin-bottom: 4px;
}

.tool-field-value {
  color: var(--text-main);
  font-size: 13px;
  line-height: 1.45;
  white-space: pre-wrap;
  word-break: break-word;
}

.tool-preview {
  margin-top: 10px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(7, 11, 18, 0.44);
  border-radius: 10px;
  padding: 10px 12px;
}

.tool-preview-label {
  color: var(--text-dim);
  font-size: 11px;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.tool-preview-body,
.tool-fallback {
  margin: 0;
  white-space: pre-wrap;
  line-height: 1.45;
  color: var(--text-main);
  background: rgba(255, 255, 255, 0.02);
  border-radius: 8px;
  padding: 8px 10px;
  overflow: auto;
}

.tool-fallback {
  margin-top: 10px;
}

.tool-preview-diff {
  display: grid;
  gap: 2px;
  font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
  font-size: 12px;
}

.tool-preview-line {
  white-space: pre-wrap;
  word-break: break-word;
  padding: 1px 6px;
  border-radius: 6px;
}

.tool-preview-line.add {
  color: #8fe3ad;
  background: rgba(71, 209, 153, 0.1);
}

.tool-preview-line.remove {
  color: #ffacac;
  background: rgba(255, 127, 127, 0.1);
}

.message.session-event {
  border-color: rgba(126, 184, 255, 0.12);
}

.message.session-event .tool-summary {
  color: var(--text-dim);
}

.message.session-event .stage-chip.primary {
  color: var(--accent-soft);
}

.message.session-event .stage-section {
  margin-top: 10px;
}

.message.session-event .tool-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.session-event-field {
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.028);
  border-radius: 10px;
  padding: 9px 11px;
}

.session-event-field-label {
  color: var(--text-dim);
  font-size: 11px;
  margin-bottom: 4px;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.session-event-field-value {
  color: var(--text-main);
  font-size: 13px;
  line-height: 1.45;
  white-space: pre-wrap;
  word-break: break-word;
}

.session-event-field-value.success {
  color: var(--ok);
  font-weight: 700;
}

.session-event-field-value.warning {
  color: var(--warn);
  font-weight: 700;
}

.session-event-field-value.error {
  color: var(--error);
  font-weight: 700;
}

.session-event-field-value.status {
  color: var(--accent-soft);
  font-weight: 700;
}

.session-event-field-value.status[data-status="done"],
.session-event-field-value.status[data-status="completed"],
.session-event-field-value.status[data-status="success"] {
  color: var(--ok);
}

.session-event-field-value.status[data-status="blocked"],
.session-event-field-value.status[data-status="failed"],
.session-event-field-value.status[data-status="error"] {
  color: var(--error);
}

.session-event-field-value.status[data-status="pending"],
.session-event-field-value.status[data-status="queued"] {
  color: var(--warn);
}

.session-event-body {
  margin: 0;
  white-space: pre-wrap;
  line-height: 1.45;
  color: var(--text-main);
  background: transparent;
  border: 0;
  border-radius: 0;
  padding: 0;
  overflow: visible;
}

.tool-preview-line.hunk {
  color: var(--accent-soft);
  background: rgba(126, 184, 255, 0.1);
}

.tool-preview-line.context {
  color: var(--text-dim);
}

.tool-preview-tail {
  margin-top: 8px;
  color: var(--text-dim);
  font-size: 12px;
}

@keyframes scheduler-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.message-text {
  margin: 0;
  white-space: pre-wrap;
  line-height: 1.45;
  font-size: 14px;
}

.composer-shell {
  padding: 12px 20px 18px;
}

.composer {
  width: min(1100px, 100%);
  margin: 0 auto;
  border: 1px solid var(--line-soft);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.03));
  border-radius: 16px;
  padding: 10px 12px;
}

.composer textarea {
  width: 100%;
  border: 0;
  background: transparent;
  color: var(--text-main);
  resize: none;
  outline: none;
  font-size: 15px;
  min-height: 30px;
  max-height: 140px;
}

.composer textarea:disabled {
  opacity: 0.65;
  cursor: not-allowed;
}

.composer-tools {
  border-top: 1px dashed rgba(255, 255, 255, 0.15);
  margin-top: 10px;
  padding-top: 8px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.composer-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  min-width: 0;
}

.composer-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-left: auto;
}

.badge {
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.08);
  padding: 4px 9px;
  font-size: 12px;
}

.badge.ok {
  border-color: rgba(71, 209, 153, 0.45);
  color: var(--ok);
}

.badge.warn {
  border-color: rgba(255, 193, 103, 0.45);
  color: var(--warn);
}

.badge.warn::before {
  content: "◌";
  display: inline-block;
  margin-right: 6px;
  animation: scheduler-spin 1s linear infinite;
}

.badge.error {
  border-color: rgba(255, 127, 127, 0.45);
  color: var(--error);
}

.send-btn {
  border: 1px solid rgba(126, 184, 255, 0.5);
  background: linear-gradient(180deg, var(--accent) 0%, var(--accent-strong) 100%);
  color: #0b1320;
  border-radius: 10px;
  font-weight: 700;
  padding: 8px 14px;
  cursor: pointer;
}

.cancel-btn {
  border-color: rgba(255, 193, 103, 0.35);
}

.cancel-btn + .send-btn {
  margin-left: 0;
}

.send-btn:disabled {
  cursor: not-allowed;
  opacity: 0.6;
}

.muted {
  color: var(--text-dim);
  font-size: 12px;
}

.hidden {
  display: none !important;
}

@media (max-width: 980px) {
  .conversation-header {
    flex-direction: column;
  }

  .header-actions {
    width: 100%;
    justify-content: flex-start;
  }

  .composer-actions {
    width: 100%;
    margin-left: 0;
    justify-content: flex-end;
  }

  .command-head {
    flex-direction: column;
    align-items: flex-start;
  }

  .command-head-actions {
    width: 100%;
    justify-content: flex-end;
  }
}

.command-panel {
  position: absolute;
  inset: 0;
  background: rgba(7, 11, 18, 0.65);
  display: grid;
  place-items: center;
  z-index: 8;
}

.command-card {
  width: min(860px, 94%);
  max-height: 88vh;
  overflow: auto;
  border: 1px solid var(--line-soft);
  border-radius: 14px;
  background: linear-gradient(180deg, #131c2a 0%, #111a26 100%);
  box-shadow: 0 26px 60px rgba(0, 0, 0, 0.44);
  padding: 14px;
}

.question-card {
  width: min(760px, 94%);
}

.command-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 14px;
}

.command-head h4 {
  margin: 0;
  font-size: 18px;
}

.command-head-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.command-runtime-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8px;
}

.command-grid {
  display: grid;
  gap: 12px;
}

.command-grid section {
  border: 1px solid var(--line-soft);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  padding: 12px;
}

.command-grid select {
  width: 100%;
  border-radius: 8px;
  border: 1px solid var(--line-soft);
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-main);
  padding: 8px 10px;
}

.command-session-list {
  display: grid;
  gap: 8px;
  max-height: 240px;
  overflow: auto;
  margin-top: 10px;
}

.command-action-grid {
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.command-action-btn {
  border: 1px solid var(--line-soft);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-main);
  text-align: center;
  padding: 8px 10px;
  font-size: 13px;
  cursor: pointer;
}

.command-action-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.command-session-btn {
  border: 1px solid var(--line-soft);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-main);
  text-align: left;
  padding: 8px;
  cursor: pointer;
}

.command-session-btn.active {
  border-color: var(--accent);
  background: rgba(126, 184, 255, 0.12);
}

.command-session-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.question-form {
  display: grid;
  gap: 14px;
}

.question-list {
  display: grid;
  gap: 12px;
}

.question-item {
  border: 1px solid var(--line-soft);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  padding: 12px;
}

.question-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 8px;
}

.question-item-label {
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dim);
  font-weight: 700;
}

.question-item-text {
  color: var(--text-main);
  line-height: 1.5;
  margin-bottom: 10px;
}

.question-options {
  display: grid;
  gap: 8px;
}

.question-option {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.02);
  padding: 9px 10px;
}

.question-option input {
  margin-top: 2px;
}

.question-option-text {
  color: var(--text-main);
  line-height: 1.4;
}

.question-custom {
  margin-top: 10px;
  display: grid;
  gap: 6px;
}

.question-custom-label {
  color: var(--text-dim);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.question-custom-input {
  width: 100%;
  border-radius: 10px;
  border: 1px solid var(--line-soft);
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-main);
  padding: 10px 12px;
  resize: vertical;
  min-height: 44px;
  font: inherit;
}

.question-form-actions {
  display: flex;
  justify-content: flex-end;
}

@media (max-width: 980px) {
  body {
    padding: 0;
  }

  .shell {
    height: 100dvh;
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: absolute;
    inset: 0 auto 0 0;
    width: min(320px, 86vw);
    transform: translateX(-102%);
    transition: transform 180ms ease;
    z-index: 5;
  }

  .shell.sidebar-open .sidebar {
    transform: translateX(0);
  }

  .workspace {
    grid-column: 1;
  }

  .hero h1 {
    font-size: clamp(28px, 10vw, 42px);
  }

  .header-actions {
    width: 100%;
    justify-content: flex-start;
  }

  .command-action-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
